ARG BBOPLACE_BASE_IMAGE=duketomlist/bboplace-bench:2.1.0
FROM ${BBOPLACE_BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1 \
    BBOPLACE_UPSTREAM_ROOT=/opt/BBOPlace-miniBench

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    mariadb-server \
    python3 \
    python3-pip \
    python3-venv \
    sysbench \
  && rm -rf /var/lib/apt/lists/*

RUN curl -LsSf https://astral.sh/uv/install.sh | sh \
  && ln -sf /root/.local/bin/uv /usr/local/bin/uv

WORKDIR /workspace

COPY pyproject.toml uv.lock README.md README.zh.md docker-compose.task-services.yml /workspace/
COPY bbo /workspace/bbo
COPY docs /workspace/docs
COPY examples /workspace/examples
COPY tests /workspace/tests
COPY workflow /workspace/workflow
COPY run.sh /workspace/run.sh
COPY scripts /workspace/scripts

RUN mkdir -p /opt/BBOPlace-miniBench/benchmarks

RUN uv sync --frozen --extra dev --extra benchmark-main

EXPOSE 8070 8080

CMD ["bash"]
